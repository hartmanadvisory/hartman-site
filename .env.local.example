# Sanity CMS — powers the "Judgment at the Forefront" event carousel.
# Get these values from https://sanity.io/manage after creating a project.
# Copy this file to .env.local and fill in real values, or leave blank to use
# the built-in hardcoded fallback events.

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-05-01
