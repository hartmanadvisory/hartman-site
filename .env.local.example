# Sanity CMS — powers the "Judgment at the Forefront" event carousel
# and the /legal/* pages. Get these values from
# https://sanity.io/manage after creating a project. Leave blank to
# use the built-in fallback content.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-05-01

# Resend — powers the /contact form (POST /api/contact).
# RESEND_API_KEY: dashboard.resend.com/api-keys (required).
# RESEND_FROM_EMAIL: verified sender on the firm's domain
#   (contact@hartmanadvisory.com once DNS is set up).
#   Falls back to Resend's sandbox `onboarding@resend.dev` if unset —
#   fine for local/preview, not for production.
# CONTACT_TO_EMAIL: destination inbox for inquiries.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
CONTACT_TO_EMAIL=

# Public site URL — drives metadataBase, OG url, sitemap, robots.
# Local dev: http://localhost:3000. Vercel prod: real domain.
NEXT_PUBLIC_SITE_URL=
